---
import BaseLayout from "@layouts/BaseLayout.astro";
import AlbumGrid from "@components/admin/AlbumGrid";
import AlbumAdmin from "@components/admin/AlbumAdmin";
import AlbumToolbar from "@components/admin/AlbumToolbar";
import { Icon } from "astro-icon/components";
---

<BaseLayout title="相册集" description="记录生活中的美好瞬间">
  <div class="mb-8">
    <div class="flex items-center justify-between mb-4">
      <h1 class="text-3xl md:text-4xl font-bold flex items-center gap-3">
        <Icon name="lucide:camera" class="text-primary" />
        <span>相册集</span>
      </h1>
      <AlbumToolbar client:only="react" />
    </div>
    <p class="text-muted-foreground text-lg">
      记录生活中的美好瞬间，每一张照片都承载着珍贵的回忆。
    </p>
  </div>

  <AlbumGrid client:only="react" />

  <div class="divider my-8">
    <Icon name="lucide:heart" class="w-12 h-12 text-primary/50" />
  </div>
</BaseLayout>

<AlbumAdmin client:only="react" />
