---
export interface ProjectCardProps {
  name: string;
  avatar: string;
  description: string;
  url: string;
  year?: number;
  tags?: string[];
  github?: string;
  npm?: string;
  badge?: string;
}

const { name, avatar, description, url, year, tags = [], github, npm, badge } = Astro.props as ProjectCardProps;

import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
---

<div
  class="group block h-full bg-base-100 rounded-2xl border border-base-200 hover:border-primary/40 shadow-sm hover:shadow-md transition-all duration-300 overflow-hidden relative"
>
  <!-- Badge (右上角) -->
  {badge && (
    <div class="absolute top-2 right-2 z-10">
      <span class="inline-flex items-center px-2 py-0.5 text-[10px] font-medium rounded bg-primary/10 text-primary border border-primary/20">
        {badge}
      </span>
    </div>
  )}

  <div class="p-4 flex flex-col h-full">
    <!-- 头部：图标 + 标题 -->
    <div class="flex items-start gap-3 mb-2">
      <div class="shrink-0">
        <div class="w-14 h-14 rounded-lg bg-base-200/50 p-1 group-hover:bg-primary/10 transition-colors duration-300">
          <div class="w-full h-full rounded-md overflow-hidden">
            {
              avatar ? (
                <Image src={avatar} width={56} height={56} format="webp" alt={name} loading="lazy" class="object-cover w-full h-full" />
              ) : (
                <div class="flex items-center justify-center w-full h-full bg-base-300 text-base-content/50">
                  <Icon name="lucide:folder" class="w-7 h-7" />
                </div>
              )
            }
          </div>
        </div>
      </div>

      <div class="flex-1 min-w-0 pt-0.5">
        <h3 class="font-bold text-base text-base-content group-hover:text-primary transition-colors truncate flex items-center gap-2">
          {name}
          {year && (
            <span class="text-xs font-normal text-base-content/40">{year}</span>
          )}
        </h3>
        <div class="text-[10px] text-base-content/40 font-mono truncate">
          {new URL(url).hostname}
        </div>
      </div>
    </div>

    <!-- Tags -->
    {tags.length > 0 && (
      <div class="flex flex-wrap gap-1 mb-2">
        {tags.map((tag: string) => (
          <span class="text-[10px] text-base-content/50 bg-base-200/50 rounded px-1.5 py-0.5">{tag}</span>
        ))}
      </div>
    )}

    <!-- 描述 -->
    <p class="text-xs text-base-content/70 line-clamp-2 leading-relaxed mb-2 flex-grow">
      {description}
    </p>

    <!-- 链接按钮 -->
    <div class="flex flex-wrap gap-1.5 pt-2 border-t border-base-200/50 mt-auto">
      <a
        href={url}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1 text-[11px] font-medium text-primary bg-primary/5 hover:bg-primary/10 rounded-md px-2 py-1 transition-colors"
      >
        <Icon name="lucide:external-link" class="w-3 h-3" />
        Website
      </a>
      {github && (
        <a
          href={github}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1 text-[11px] font-medium text-base-content/60 bg-base-200/50 hover:bg-base-200 rounded-md px-2 py-1 transition-colors"
        >
          <Icon name="lucide:github" class="w-3 h-3" />
          GitHub
        </a>
      )}
      {npm && (
        <a
          href={npm}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1 text-[11px] font-medium text-base-content/60 bg-base-200/50 hover:bg-base-200 rounded-md px-2 py-1 transition-colors"
        >
          <Icon name="lucide:package" class="w-3 h-3" />
          NPM
        </a>
      )}
    </div>
  </div>
</div>
