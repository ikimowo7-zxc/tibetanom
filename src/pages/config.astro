---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { ConfigPage } from '@/components/write/ConfigPage';
import { MUSIC_CONFIG } from '@/config';
import fs from 'node:fs';
import path from 'node:path';

const serverPlaylists = JSON.stringify(MUSIC_CONFIG?.playlists || []);
// 在 dev 模式下把完整配置 YAML 注入客户端，避免前端 fetch 不到
const configYaml = JSON.stringify(fs.readFileSync(path.resolve('ryuchan.config.yaml'), 'utf-8'));
---

<BaseLayout title="站点配置" showSidebar={false} showBanner={false} isIndexed={false}>
    <script define:vars={{ serverPlaylists, configYaml }}>
        window.__SERVER_PLAYLISTS__ = JSON.parse(serverPlaylists);
        window.__SERVER_CONFIG__ = configYaml;
    </script>
    <ConfigPage client:only="react" />
</BaseLayout>

